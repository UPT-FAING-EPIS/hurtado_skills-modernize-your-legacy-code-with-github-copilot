{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Node.js Accounting App",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/accounting/index.js",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "outputCapture": "console"
    },
    {
      "name": "Launch Node.js Accounting App (with auto-restart)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/accounting/index.js",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "runtimeArgs": [
        "--watch"
      ]
    }
  ]
}
